<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.example.messageapp"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permisos de Internet -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    
    <!-- Permisos de Notificaciones -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    
    <!-- Permisos de Contactos (opcional, para futura funcionalidad) -->
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    
    <!-- Permisos JPush -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    
    <application
        android:name=".App"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MessageApp">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MessageApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        
        <!-- JPush BroadcastReceiver para manejar notificaciones -->
        <receiver
            android:name=".push.JPushBroadcastReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="cn.jiguang.jpush.intent.REGISTRATION" />
                <action android:name="cn.jiguang.jpush.intent.MESSAGE_RECEIVED" />
                <action android:name="cn.jiguang.jpush.intent.NOTIFICATION_RECEIVED" />
                <action android:name="cn.jiguang.jpush.intent.NOTIFICATION_OPENED" />
                <action android:name="cn.jiguang.jpush.intent.CONNECTION" />
                <action android:name="cn.jiguang.jpush.intent.RICHPUSH_CALLBACK" />
                <category android:name="${applicationId}" />
            </intent-filter>
        </receiver>
        
        <!-- JPush Service para mensajes en foreground -->
        <service
            android:name=".push.JPushService"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="cn.jiguang.jpush.service" />
            </intent-filter>
        </service>
        
        <!-- Receiver para boot completado (reiniciar JPush) -->
        <receiver
            android:name="cn.jiguang.jpush.android.service.JPushBootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.REBOOT" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
        
        <!-- Canal de notificación para Android 13+ -->
        <meta-data
            android:name="JPUSH_CHANNEL"
            android:value="DEFAULT" />
        <meta-data
            android:name="JPUSH_APPKEY"
            android:value="${JPUSH_APPKEY}" />

    </application>
</manifest>
